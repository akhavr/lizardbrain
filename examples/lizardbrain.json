{
  "memoryDbPath": "./lizardbrain.db",
  "batchSize": 40,
  "minMessages": 5,

  "llm": {
    "baseUrl": "https://api.openai.com/v1",
    "model": "gpt-5-nano"
  },

  "_comment_context": "Enable context injection to let the LLM see existing knowledge during extraction",
  "context": {
    "enabled": false,
    "tokenBudget": 500,
    "recencyDays": 30
  },

  "_comment_embedding": "Uncomment below to enable hybrid vector search",
  "embedding": {
    "enabled": false,
    "baseUrl": "https://api.openai.com/v1",
    "model": "text-embedding-3-small"
  },

  "source": {
    "type": "sqlite",
    "path": "./chat.db",
    "table": "messages",
    "columns": {
      "id": "id",
      "content": "content",
      "sender": "sender_name",
      "timestamp": "created_at"
    },
    "filter": "role = 'user'"
  }
}
